{
  "name": "nexgraph",
  "version": "0.1.0",
  "description": "Headless Code Intelligence Engine — Build Knowledge Graphs, Let AI Agents Consume Them",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:migrate": "tsx src/db/migrate.ts",
    "mcp": "tsx src/mcp/stdio.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:generate": "tsx scripts/generate-api-docs.ts",
    "docs:dev": "npm run --prefix docs dev",
    "docs:build": "npm run --prefix docs build",
    "docs:preview": "npm run --prefix docs preview",
    "plugin:install": "tsx scripts/install-claude-plugin.ts"
  },
  "bin": {
    "nexgraph": "dist/mcp/stdio.js"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.69",
    "@ai-sdk/cohere": "^3.0.22",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/mistral": "^3.0.21",
    "@ai-sdk/openai": "^3.0.37",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-openapi": "^0.18.4",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "adm-zip": "^0.5.16",
    "ai": "^6.0.105",
    "dotenv": "^16.4.7",
    "graphology": "^0.26.0",
    "graphology-indices": "^0.17.0",
    "graphology-types": "^0.24.8",
    "graphology-utils": "^2.4.4",
    "mnemonist": "^0.39.0",
    "pandemonium": "^2.4.1",
    "hono": "^4.7.4",
    "ignore": "^7.0.5",
    "pg": "^8.19.0",
    "pg-boss": "^12.13.0",
    "picomatch": "^4.0.3",
    "pino": "^9.6.0",
    "simple-git": "^3.32.3",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.13.5",
    "@types/pg": "^8.16.0",
    "@types/picomatch": "^4.0.2",
    "eslint": "^9.21.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vitest": "^4.0.18"
  }
}
