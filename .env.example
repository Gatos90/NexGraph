# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexgraph
DB_POOL_MIN=2
DB_POOL_MAX=10

# API
API_PREFIX=/api/v1

# Ingestion
MAX_FILE_SIZE=1048576        # Max file size in bytes (default 1 MB)
INGESTION_TEMP_DIR=          # Temp dir for clones/extracts (default: os.tmpdir())
WORKER_POOL_SIZE=0           # Worker threads for AST parsing (0 = auto: CPU cores - 1)

# Embeddings
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-xs
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_PARALLEL_CALLS=2
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
PROJECT_SECRETS_ENCRYPTION_KEY=
